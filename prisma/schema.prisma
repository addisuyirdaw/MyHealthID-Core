// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  PHARMACIST
  RECEPTIONIST
}

model User {
  id        String   @id @default(uuid()) @map("_id")
  email     String   @unique
  password  String
  role      Role     @default(RECEPTIONIST)
  
  firstName String?
  lastName  String?
  professionalLicenseNumber String?

  nationalId String? @unique
  otpCode    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  investigations Investigation[]
}

enum Ward {
  OPD_OUTPATIENT             @map("OPD / Outpatient")
  EMERGENCY                  @map("Emergency")
  MEDICAL_WARD               @map("Medical Ward")
  SURGICAL_WARD              @map("Surgical Ward")
  MATERNITY_WARD             @map("Maternity Ward")
  GYNECOLOGY                 @map("Gynecology")
  PEDIATRIC_WARD             @map("Pediatric Ward")
  NEWBORN_NEONATAL           @map("Newborn / Neonatal")
  INPATIENT_GENERAL_WARD     @map("Inpatient / General Ward")
  LABORATORY                 @map("Laboratory")
  PHARMACY                   @map("Pharmacy")
  PROCEDURE_MINOR_OPERATION  @map("Procedure / Minor Operation")
  ISOLATION                  @map("Isolation")
  SUPPORT_UNITS              @map("Support Units")
}

enum TriageStatus {
  RED
  YELLOW
  GREEN
  WAITING_FOR_TRIAGE
}

enum PriorityLevel {
  EMERGENCY
  URGENT
  ROUTINE
}

/// Result of a structured clinical screening (Green / Yellow / Red).
enum ScreeningTriageLevel {
  GREEN
  YELLOW
  RED
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
}

model Patient {
  id                String   @id @default(uuid()) @map("_id")
  healthId          String   @unique
  nationalId        String?
  faydaId           String?  @map("fayda_id")
  hospitalId        String?  @map("hospital_id")
  fcn               String?  @map("fcn")
  internalId        String   @unique @map("internal_id")
  isMinor           Boolean  @default(false)
  guardianId        String?
  parentFaydaId     String?  @map("parent_fayda_id")
  isSynced          Boolean  @default(false)
  email             String?
  otpCode           String?

  // Queue Information
  phoneNumber       String?
  queuePosition     Int      @default(0)
  estimatedWait     Int      @default(0)

  // 1. Patient Registration Data (From DATA 1)
  fullName          String
  age               Int
  sex               String
  religion          String?
  occupation        String?
  maritalStatus     String?
  educationalStatus String?
  dateOfAdmission   DateTime @default(now())

  // Address broken down
  addressCountry    String?
  addressRegion     String?
  addressZone       String?
  addressWoreda     String?
  addressKebele     String?

  dateOfBirth       DateTime?

  // Contacts
  emergencyContactName  String?
  emergencyContactPhone String?

  // Smart Fields
  chiefComplaint        String?
  detailedSituation     String?
  reasonForVisit        String?
  suspectedDisease      String?
  preExistingConditions String?
  familyHistory         String?
  surgicalHistory       String?
  allergyInformation    String?
  /// Medical Record Number (hospital chart); distinct from healthId when assigned.
  mrn                   String?
  bloodGroup            String?
  emergencyFlag         Boolean  @default(false)
  isRestricted          Boolean  @default(false)  @map("is_restricted")
  externalSystemId      String?
  legacyProviderName    String?
  serviceType           String?  @default("OPD")

  ward                  Ward     @default(OPD_OUTPATIENT)
  triageStatus          TriageStatus @default(WAITING_FOR_TRIAGE)
  priorityLevel         PriorityLevel @default(ROUTINE)
  examStatus            String   @default("PENDING")
  status                String?  @default("ACTIVE")

  // AI Smart Triage Engine — persisted once, shared across all wards
  aiPriorityScore       Float?   @map("ai_priority_score")   // 0-100
  aiRecommendation      String?  @map("ai_recommendation")   // JSON string
  aiSymptomSummary      String?  @map("ai_symptom_summary")  // For the Doctor's Command Center

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  vitals            Vitals[]
  investigations    Investigation[]
  prescriptions     Prescription[]
  referrals         Referral[]
  clinicalExam      ClinicalExamination?
  queues            Queue[]
  accessLogs        AccessLog[]
  journals          PatientJournal[]
  screenings        Screening[]
  medicalTimeline   MedicalTimelineEntry[]

  @@index([nationalId])
  @@index([faydaId])
  @@index([hospitalId])
  @@index([fcn])
}

/// Append-only clinical timeline (never update rows — new facts = new documents).
enum MedicalTimelineEntryType {
  SECTION_NOTE
  VITALS
  NURSING_PROGRESS
  SYSTEMS_EXAM
}

model VerifiedRegistry {
  id          String   @id @default(uuid()) @map("_id")
  fin         String   @unique
  fcn         String   @unique
  fullName    String
  dateOfBirth DateTime
  gender      String

  // Optional: store source record metadata
  issuedAt    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("verified_registry")
}

/// Permanent registration snapshot for staff lookup by FIN or phone (national intake).
model VerifiedCitizen {
  id            String   @id @default(uuid()) @map("_id")
  nationalFin   String?  @unique @map("national_fin")
  phoneDigits   String?  @unique @map("phone_digits")
  fullName      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("verified_citizens")
}

model ClinicalExamination {
  id                String   @id @default(uuid()) @map("_id")
  patientId         String   @unique
  
  generalAppearance String?
  heent             String?
  lymphoglandular   String?
  respiratory       String?
  cardiovascular    String?
  abdomen           String?
  genitourinary     String?
  musculoskeletal   String?
  integumentary     String?
  neurological      String?
  
  clinicalNotes     String?  // Final impressions
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Vitals {
  id        String   @id @default(uuid()) @map("_id")
  patientId String
  
  // Mandatory Vital Signs
  bp        String   // Blood Pressure e.g., "120/80"
  pulse     Int      // Pulse Rate (PR)
  rr        Int      // Respiratory Rate (RR)
  temp      Float    // Temperature (T°)
  spO2      Float    // Blood Oxygen
  bmi       Float?   // Body Mass Index
  painLevel Int?     // Pain Level 1-10
  weightKg  Float?
  heightCm  Float?
  
  createdAt DateTime @default(now())

  // Relations
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MedicalTimelineEntry {
  id               String                     @id @default(uuid()) @map("_id")
  patientId        String
  createdAt        DateTime                   @default(now())
  professionalName String
  /// One-line immutable audit summary (searchable list).
  logEntry         String
  entryType        MedicalTimelineEntryType
  /// One of: identification | past_history | vitals | clinical_exam | nursing_progress | investigations | medications | referrals
  emrSection       String
  title            String?
  body             String?
  structuredData   Json?
  relatedVitalsId  String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([patientId, emrSection])
  @@map("medical_timeline_entries")
}

enum InvestigationStatus {
  PENDING
  COMPLETED
}

model Investigation {
  id          String   @id @default(uuid()) @map("_id")
  patientId   String
  doctorId    String?
  
  testName    String
  category    String? 
  department  String?

  status      InvestigationStatus @default(PENDING)
  result      String?  

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      User?    @relation(fields: [doctorId], references: [id])
}

enum PrescriptionStatus {
  PENDING
  DISPENSED
}

model Prescription {
  id          String   @id @default(uuid()) @map("_id")
  patientId   String
  doctorId    String?
  
  drugName    String   @map("medication")
  dosage      String
  frequency   String   @default("N/A")
  duration    String   @default("N/A")
  notes       String?

  status      PrescriptionStatus @default(PENDING)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Referral {
  id                  String   @id @default(uuid()) @map("_id")
  patientId           String
  
  reason              String
  destinationFacility String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id          String   @id @default(uuid()) @map("_id")
  isBreakTime Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model Queue {
  id          String       @id @default(uuid()) @map("_id")
  patientId   String
  status      QueueStatus  @default(WAITING)
  checkInTime DateTime     @default(now())

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum AccessLogAction {
  VIEW
  BREAK_GLASS
  RESTRICT
  UNRESTRICT
}

model AccessLog {
  id              String          @id @default(uuid()) @map("_id")
  patientId       String
  accessedByName  String
  facility        String          @default("Debre Berhan Hospital")
  role            String
  action          AccessLogAction @default(VIEW)
  createdAt       DateTime        @default(now())

  // Relations
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientJournal {
  id              String   @id @default(uuid()) @map("_id")
  patientId       String
  
  symptoms        String?
  mood            String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

/// Structured multi-condition screening (TB, HTN, Diabetes, etc.) with raw answers + computed triage.
model Screening {
  id                   String               @id @default(uuid()) @map("_id")
  patientId            String
  screeningType        String
  answers              Json
  triageResult         ScreeningTriageLevel
  riskScore            Int                  @default(0)
  interruptedEmergency Boolean              @default(false)

  /// Bilingual post-screening guidance shown to the patient/staff.
  guidanceText Json?

  /// Vitals snapshot for Hypertension / Cardiac (history over repeat screenings).
  sbp      Float?
  dbp      Float?
  weightKg Float?
  heightCm Float?
  bmi      Float?

  bpStageLabel         String?
  diabetesInterpretation Json?
  computedDetails      Json?

  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, screeningType])
  @@index([patientId, createdAt])
  @@map("screenings")
}
