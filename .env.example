# Copy to `.env` or `.env.local` (Next.js loads both; do not commit real secrets).
# Must be MongoDB — Prisma rejects any other protocol.
# Password special characters must be URL-encoded (e.g. # → %23, @ → %40).
#
# Example if the password were literally Addi123# :
# DATABASE_URL="mongodb+srv://myhealthid2_db_user:Addi123%23@cluster0.jpr7vag.mongodb.net/MyHealthID?retryWrites=true&w=majority&appName=Cluster0"
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/MyHealthID?retryWrites=true&w=majority&appName=Cluster0"
